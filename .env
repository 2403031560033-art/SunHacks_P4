# ------------------------------------------------------------
# 🌐 VERCEL DEPLOYMENT CONFIGURATION
# ------------------------------------------------------------
# For easy deployment to Vercel, copy all of these variables 
# into the Vercel Dashboard -> Settings -> Environment Variables.

# -- FRONTEND VARIABLES --
# In Vercel, change this to your deployed backend URL.
# (Vite requires the VITE_ prefix to read environment variables)
VITE_API_URL=http://localhost:5000


# -- BACKEND VARIABLES --
# Standard Flask configuration
FLASK_APP=backend/app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Change this to a secure random string in production!
JWT_SECRET=sunhacks-super-secure-jwt-secret-key-2026
